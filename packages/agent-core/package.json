{
  "name": "@archcode/agent-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun run test:unit && bun run test:integration && bun run test:arch",
    "test:unit": "bun test --parallel=4 --path-ignore-patterns='**/*.integration.test.ts' --path-ignore-patterns='**/__arch__/**'",
    "test:integration": "bun test --isolate .integration.test.ts",
    "test:arch": "bun test --isolate ./src/__arch__",
    "tool-contract:measure": "bun run scripts/tool-contract-measure.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/provider-utils": "^4.0.26",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@archcode/protocol": "workspace:*",
    "@archcode/utils": "workspace:*",
    "@truto/turndown-plugin-gfm": "^1.0.2",
    "ai": "^6.0.174",
    "diff": "^9.0.0",
    "fuzzysort": "^3.1.0",
    "jsdom": "^29.1.1",
    "turndown": "^7.2.4",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^4.4.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "js-tiktoken": "1.0.21",
    "typescript": "^6.0.3"
  }
}
