{
  "name": "specra",
  "version": "0.1.0",
  "private": true,
  "description": "A long-running coding CLI agent that coordinates a virtual software company of AI roles — PM, backend, frontend, QA, PR review — all orchestrated from your terminal.",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "bin": {
    "specra": "./apps/server/src/main.ts"
  },
  "files": [
    "apps/server/src/**/*.ts",
    "apps/web/dist/**",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "server": "bun --hot apps/server/src/main.ts",
    "start": "bun apps/server/src/main.ts",
    "web": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "dev": "concurrently -n server,web -c blue,green \"bun run server\" \"bun run web\"",
    "build": "bun run typecheck && bun run web:build",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@specra/agent-core": "workspace:*",
    "@specra/protocol": "workspace:*",
    "@specra/server": "workspace:*",
    "@specra/web": "workspace:*",
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@truto/turndown-plugin-gfm": "^1.0.2",
    "ai": "^6.0.174",
    "fuzzysort": "^3.1.0",
    "hono": "^4.12.19",
    "jsdom": "^29.1.1",
    "turndown": "^7.2.4",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^4.4.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/bun": "^1.3.13",
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.4",
    "tailwindcss": "^4.1.0",
    "typescript": "^6.0.3",
    "vite": "^6.3.0"
  }
}
