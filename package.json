{
  "name": "specra",
  "version": "0.1.0",
  "private": true,
  "description": "A long-running coding CLI agent that coordinates a virtual software company of AI roles — PM, backend, frontend, QA, PR review — all orchestrated from your terminal.",
  "type": "module",
  "bin": {
    "specra": "./src/main.ts"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "start": "bun src/main.ts",
    "server": "bun --hot src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@truto/turndown-plugin-gfm": "^1.0.2",
    "ai": "^6.0.174",
    "ink": "^7.0.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.5",
    "turndown": "^7.2.4",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^4.4.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "typescript": "^6.0.3"
  }
}
