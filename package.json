{
  "name": "specra",
  "version": "0.1.0",
  "private": true,
  "description": "A long-running coding CLI agent that coordinates a virtual software company of AI roles — PM, backend, frontend, QA, PR review — all orchestrated from your terminal.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": ["apps/*", "packages/*"],
  "bin": {
    "specra": "./apps/server/src/main.ts"
  },
  "scripts": {
    "web:build": "bun run --cwd apps/web build",
    "dev": "turbo run dev",
    "build": "bun run typecheck && bun run scripts/build.ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "dependencies": {
    "@specra/agent-core": "workspace:*",
    "@specra/protocol": "workspace:*",
    "@specra/server": "workspace:*",
    "@specra/web": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vite": "^6.3.0"
  }
}
